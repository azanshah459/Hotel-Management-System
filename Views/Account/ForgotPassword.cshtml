@model HotelManagement.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="page-header">
    <h1>Reset <em>Password</em></h1>
    <p>Update your password to regain access</p>
</div>

<div class="form-card">
    <form asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" placeholder="Enter your username" />
            <span asp-validation-for="Username" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control" placeholder="Enter a new password" />
            <span asp-validation-for="NewPassword" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm your new password" />
            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <div style="display:flex; gap:0.75rem; margin-top:1.75rem;">
            <button type="submit" class="btn btn-gold">Update Password</button>
            <a asp-action="Login" class="btn btn-outline">Back to Login</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
