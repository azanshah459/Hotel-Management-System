@model HotelManagement.Models.UserDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
    var completed = Math.Max(Model.TotalBookings - Model.UpcomingBookings, 0);
}

<div class="dashboard-header reveal">
    <div>
        <h1>Hello, <em>@Model.UserName</em></h1>
        <p>Your booking summary at a glance</p>
    </div>
    <div class="dashboard-actions">
        <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary">Book a Room</a>
        <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-outline">View My Bookings</a>
    </div>
</div>

<div class="dashboard-grid">
    <div class="kpi-card reveal">
        <div class="kpi-label">Total Bookings</div>
        <div class="kpi-value">@Model.TotalBookings</div>
        <div class="kpi-sub">All stays to date</div>
    </div>
    <div class="kpi-card reveal">
        <div class="kpi-label">Upcoming</div>
        <div class="kpi-value">@Model.UpcomingBookings</div>
        <div class="kpi-sub">Trips on the calendar</div>
    </div>
    <div class="kpi-card reveal">
        <div class="kpi-label">Total Spend</div>
        <div class="kpi-value">PKR @Model.TotalSpend.ToString("N0")</div>
        <div class="kpi-sub">Lifetime booking value</div>
    </div>
    <div class="trend-card reveal">
        <div class="trend-title">Stay Timeline</div>
        <div style="margin-top:0.6rem; font-size:1.6rem; font-family:'Cormorant Garamond',serif; color:var(--gold);">
            @Model.UpcomingBookings upcoming
        </div>
        <div class="trend-bars">
            <div class="trend-bar"><span style="width:@(Model.TotalBookings == 0 ? 0 : (Model.UpcomingBookings * 100 / Model.TotalBookings))%"></span></div>
            <div class="trend-bar"><span style="width:@(Model.TotalBookings == 0 ? 0 : (completed * 100 / Model.TotalBookings))%"></span></div>
        </div>
        <div style="margin-top:0.7rem; font-size:0.75rem; color:#D9CCB5; letter-spacing:0.12em; text-transform:uppercase;">
            Completed @completed
        </div>
    </div>
</div>

<div class="activity-card reveal">
    <div class="activity-header">
        <h3>Recent Bookings</h3>
        <span class="chip">Latest 5</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Ref #</th>
                <th>Room</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Total (PKR)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.RecentBookings)
            {
                <tr>
                    <td style="font-family:'Cormorant Garamond',serif; font-size:1.05rem; color:var(--gold);">#@booking.Id</td>
                    <td>Room @booking.Room?.RoomNumber</td>
                    <td>@booking.BookingDate.ToString("MMM dd")</td>
                    <td>@booking.CheckOutDate.ToString("MMM dd")</td>
                    <td>@booking.TotalPrice.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.RecentBookings.Any())
    {
        <p style="text-align:center; padding:2rem; color:var(--text-muted);">No bookings yet. Book your first stay.</p>
    }
</div>
