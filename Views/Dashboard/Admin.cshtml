@model HotelManagement.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var occupancy = Math.Clamp(Model.OccupancyRate, 0, 100);
    var availability = 100 - occupancy;
}

<div class="dashboard-header reveal">
    <div>
        <h1>Admin <em>Dashboard</em></h1>
        <p>Operational overview and booking activity</p>
    </div>
    <div class="dashboard-actions">
        <a asp-controller="Rooms" asp-action="AdminIndex" class="btn btn-outline">Manage Rooms</a>
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary">View All Bookings</a>
    </div>
</div>

<div class="dashboard-grid">
    <div class="kpi-card reveal">
        <div class="kpi-label">Total Rooms</div>
        <div class="kpi-value">@Model.TotalRooms</div>
        <div class="kpi-sub">Inventory across the property</div>
    </div>
    <div class="kpi-card reveal">
        <div class="kpi-label">Available</div>
        <div class="kpi-value">@Model.AvailableRooms</div>
        <div class="kpi-sub">Rooms ready to book</div>
    </div>
    <div class="kpi-card reveal">
        <div class="kpi-label">Total Bookings</div>
        <div class="kpi-value">@Model.TotalBookings</div>
        <div class="kpi-sub">Active reservations</div>
    </div>
    <div class="kpi-card reveal">
        <div class="kpi-label">Revenue</div>
        <div class="kpi-value">PKR @Model.TotalRevenue.ToString("N0")</div>
        <div class="kpi-sub">Overall booking value</div>
    </div>
    <div class="trend-card reveal">
        <div class="trend-title">Occupancy vs Availability</div>
        <div style="margin-top:0.6rem; font-size:1.6rem; font-family:'Cormorant Garamond',serif; color:var(--gold);">
            @occupancy% Occupied
        </div>
        <div class="trend-bars">
            <div class="trend-bar"><span style="width:@occupancy%"></span></div>
            <div class="trend-bar"><span style="width:@availability%"></span></div>
        </div>
        <div style="margin-top:0.7rem; font-size:0.75rem; color:#D9CCB5; letter-spacing:0.12em; text-transform:uppercase;">
            Availability @availability%
        </div>
    </div>
</div>

<div class="activity-card reveal">
    <div class="activity-header">
        <h3>Recent Bookings</h3>
        <span class="chip">Latest 5</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Ref #</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Total (PKR)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.RecentBookings)
            {
                <tr>
                    <td style="font-family:'Cormorant Garamond',serif; font-size:1.05rem; color:var(--gold);">#@booking.Id</td>
                    <td>@booking.UserName</td>
                    <td>Room @booking.Room?.RoomNumber</td>
                    <td>@booking.BookingDate.ToString("MMM dd")</td>
                    <td>@booking.CheckOutDate.ToString("MMM dd")</td>
                    <td>@booking.TotalPrice.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.RecentBookings.Any())
    {
        <p style="text-align:center; padding:2rem; color:var(--text-muted);">No recent bookings yet.</p>
    }
</div>
