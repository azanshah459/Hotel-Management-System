@model HotelManagement.Models.Room
@{
    ViewData["Title"] = "Edit Room";
}

<div class="page-header">
    <h1>Edit <em>Room @Model.RoomNumber</em></h1>
    <p>Update the room details below</p>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="RoomNumber" class="form-label"></label>
            <input asp-for="RoomNumber" class="form-control" />
            <span asp-validation-for="RoomNumber" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Type" class="form-label"></label>
            <select asp-for="Type" class="select-control">
                <option>Standard</option>
                <option>Deluxe</option>
                <option>Suite</option>
                <option>Presidential Suite</option>
                <option>Family Room</option>
            </select>
            <span asp-validation-for="Type" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Price" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="form-label" style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                <input asp-for="IsAvailable" type="checkbox" style="width:16px;height:16px;accent-color:var(--gold);" />
                Mark as Available
            </label>
        </div>

        <div style="display:flex; gap:0.75rem; margin-top:1.75rem;">
            <button type="submit" class="btn btn-gold">Save Changes</button>
            <a asp-action="AdminIndex" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
