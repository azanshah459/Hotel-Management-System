@model IEnumerable<HotelManagement.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="page-header">
    <h1>My <em>Bookings</em></h1>
    <p>Review and manage your reservations</p>
</div>

@if (User.IsInRole("Admin"))
{
    <div style="margin-bottom:1.5rem; display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
        <form method="get" asp-action="MyBookings" style="display:flex; gap:0.5rem; flex:1; max-width:420px;">
            <input name="guestName" value="@ViewBag.GuestName" class="form-control" placeholder="Search by guest name..." style="flex:1;" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
        @if (!string.IsNullOrWhiteSpace(ViewBag.GuestName as string))
        {
            <a asp-action="MyBookings" class="btn btn-outline btn-sm">Clear</a>
        }
    </div>
}

@if (!Model.Any())
{
    <div style="text-align:center; padding:3rem; background:var(--white); border:1px solid var(--border); border-radius:4px;">
        <p style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:var(--text-muted); font-weight:300;">
            @(string.IsNullOrWhiteSpace(ViewBag.GuestName as string) ? "Search for bookings to begin" : "No bookings found")
        </p>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ref #</th>
                    <th>Room</th>
                    <th>Type</th>
                    <th>Check-In</th>
                    <th>Check-Out</th>
                    <th>Nights</th>
                    <th>Total (PKR)</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td style="font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--gold);">#@b.Id</td>
                        <td style="font-weight:600;">Room @b.Room?.RoomNumber</td>
                        <td><span class="room-type-badge">@b.Room?.Type</span></td>
                        <td>@b.BookingDate.ToString("MMM dd, yyyy")</td>
                        <td>@b.CheckOutDate.ToString("MMM dd, yyyy")</td>
                        <td>@b.Nights</td>
                        <td>@b.TotalPrice.ToString("N0")</td>
                        <td>
                            <div style="display:flex; gap:0.4rem; align-items:center;">
                                <a asp-action="Invoice" asp-route-id="@b.Id" class="btn btn-outline btn-sm">Invoice</a>
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Cancel booking #@b.Id? This cannot be undone.');">
                                    <input type="hidden" name="returnUrl" value="user" />
                                    <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
