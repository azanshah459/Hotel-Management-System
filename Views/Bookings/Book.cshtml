@model HotelManagement.Models.Booking
@{
    ViewData["Title"] = "Book a Room";
    var room = Model.Room;
}

<div class="page-header">
    <h1>Book <em>Room @room?.RoomNumber</em></h1>
    <p>Complete your reservation details below</p>
</div>

<div style="display:grid; grid-template-columns:1fr 340px; gap:2rem; align-items:start; flex-wrap:wrap;">

    <div class="form-card" style="max-width:100%;">
        <h3 style="font-family:'Cormorant Garamond',serif; font-size:1.2rem; font-weight:400; margin-bottom:1.5rem; color:var(--text-muted); letter-spacing:0.05em; text-transform:uppercase; font-size:0.8rem;">Guest Details</h3>

        <form asp-action="Book" method="post" data-rate="@(room?.Price.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))">
            <input type="hidden" asp-for="RoomId" />
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" readonly />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="BookingDate" class="form-label"></label>
                <input asp-for="BookingDate" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="BookingDate" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CheckOutDate" class="form-label"></label>
                <input asp-for="CheckOutDate" class="form-control" type="date" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                <span asp-validation-for="CheckOutDate" class="field-validation-error"></span>
            </div>

            <div style="display:flex; gap:1rem; margin:1rem 0 1.5rem; flex-wrap:wrap;">
                <div class="role-pill">Nights <strong id="nightsValue">1</strong></div>
                <div class="role-pill">Total <strong id="totalValue">PKR @room?.Price.ToString("N0")</strong></div>
            </div>

            <div style="display:flex; gap:0.75rem; margin-top:1.75rem;">
                <button type="submit" class="btn btn-gold">Confirm Booking</button>
                <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>

    @if (room != null)
    {
        <div class="card" style="padding:0; overflow:hidden;">
            <div style="background:var(--charcoal); padding:1.25rem; text-align:center;">
                <p style="color:var(--gold); font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.25rem;">Your Selection</p>
                <p style="font-family:'Cormorant Garamond',serif; font-size:2rem; font-weight:300; color:var(--white);">Room @room.RoomNumber</p>
            </div>
            <div style="padding:1.5rem;">
                <div class="detail-row">
                    <span class="detail-label">Type</span>
                    <span class="detail-value">@room.Type</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Rate</span>
                    <span class="detail-value" style="color:var(--gold);">PKR @room.Price.ToString("N0")/night</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Status</span>
                    <span class="badge badge-available">Available</span>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var form = document.querySelector('form[data-rate]');
            if (!form) return;

            var rate = parseFloat(form.getAttribute('data-rate')) || 0;
            var checkIn = form.querySelector('[name="BookingDate"]');
            var checkOut = form.querySelector('[name="CheckOutDate"]');
            var nightsEl = document.getElementById('nightsValue');
            var totalEl = document.getElementById('totalValue');

            function updateTotals() {
                if (!checkIn.value || !checkOut.value) return;
                var start = new Date(checkIn.value);
                var end = new Date(checkOut.value);
                var diff = Math.round((end - start) / 86400000);
                var nights = diff < 1 ? 1 : diff;
                nightsEl.textContent = nights;
                totalEl.textContent = 'PKR ' + (rate * nights).toLocaleString('en-PK');
            }

            checkIn.addEventListener('change', function () {
                if (checkIn.value) {
                    var start = new Date(checkIn.value);
                    var minCheckout = new Date(start.getTime() + 86400000);
                    checkOut.min = minCheckout.toISOString().slice(0, 10);
                    if (new Date(checkOut.value) <= start) {
                        checkOut.value = checkOut.min;
                    }
                }
                updateTotals();
            });
            checkOut.addEventListener('change', updateTotals);

            if (checkIn.value) {
                var start = new Date(checkIn.value);
                var minCheckout = new Date(start.getTime() + 86400000);
                checkOut.min = minCheckout.toISOString().slice(0, 10);
            }

            updateTotals();
        })();
    </script>
}
