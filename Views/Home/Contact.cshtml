@{
    ViewData["Title"] = "Contact Us";
}

<div class="page-header reveal">
    <h1>Contact <em>FAST Hotel</em></h1>
    <p>We are here to assist you with your stay</p>
</div>

<div class="auth-shell">
    <div class="auth-hero reveal" style="background: linear-gradient(135deg, #1A1A1A 0%, #2B2B2B 45%, #1F1A14 100%);">
        <h2>Get in Touch</h2>
        <p>Whether you're inquiring about a future stay, planning an event, or simply saying hello, our dedicated team is at your service 24/7.</p>
        
        <div class="auth-highlight" style="margin-top: 2rem;">
            <div class="auth-highlight-item">
                <div class="auth-dot"></div>
                <span><strong>Address:</strong> Opposite FAST University, Near Bhains Colony, Karachi</span>
            </div>
            <div class="auth-highlight-item">
                <div class="auth-dot"></div>
                <span><strong>Phone:</strong> +92-303-7789117</span>
            </div>
            <div class="auth-highlight-item">
                <div class="auth-dot"></div>
                <span><strong>Email:</strong> reservations@fasthotel.com</span>
            </div>
        </div>
    </div>

    <div class="form-card auth-card">
        <h3 style="font-family:'Cormorant Garamond',serif; font-size:1.6rem; color:var(--charcoal); margin-bottom:1.5rem;">Send a Message</h3>
        <form method="post" action="#">
            <div class="form-group">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" placeholder="Your full name" required />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
                <label class="form-label">Subject</label>
                <input type="text" class="form-control" placeholder="Inquiry topic" required />
            </div>
            <div class="form-group">
                <label class="form-label">Message</label>
                <textarea class="form-control" rows="5" placeholder="How can we help you?" required></textarea>
            </div>
            <button type="button" onclick="alert('Message sent successfully! We will get back to you shortly.')" class="btn btn-primary" style="width: 100%">Send Message</button>
        </form>
    </div>
</div>
