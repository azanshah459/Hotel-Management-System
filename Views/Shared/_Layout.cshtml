<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Grand Horizon Hotel</title>
    <meta name="description" content="Grand Horizon Hotel Management System - Orchestrate rooms, bookings, and guest experiences with precision and elegance." />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🏨</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --gold: #B8904D;
            --gold-light: #D9C092;
            --gold-dark: #8B6914;
            --charcoal: #121212;
            --charcoal-soft: #2A2A2A;
            --cream: #FDFBF7;
            --cream-dark: #F2EFE9;
            --text-main: #181818;
            --text-muted: #595959;
            --white: #FFFFFF;
            --success: #2E6A42;
            --error: #AA3030;
            --border: #DDD5C7;
        }

        body {
            font-family: 'Jost', sans-serif;
            background-color: var(--cream);
            color: var(--text-main);
            font-weight: 400;
            line-height: 1.65;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── NAVBAR ── */
        nav {
            background: rgba(26, 26, 26, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding: 0 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid rgba(201, 169, 110, 0.3);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        }

        .nav-brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--gold);
            text-decoration: none;
            letter-spacing: 0.05em;
        }

        .nav-brand span {
            color: var(--white);
            font-weight: 300;
            font-style: italic;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            list-style: none;
        }

        .nav-links a {
            color: #E6E6E6;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            transition: color 0.2s, background 0.2s;
        }

        .nav-links a:hover,
        .nav-link-button:hover {
            color: var(--gold);
            background: rgba(184, 144, 77, 0.12);
        }

        .nav-link-button {
            background: none;
            border: none;
            color: #E6E6E6;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            cursor: pointer;
            transition: color 0.2s, background 0.2s;
        }

        .nav-divider {
            width: 1px;
            height: 20px;
            background: #444;
            margin: 0 0.5rem;
        }

        /* ── PAGE WRAPPER ── */
        .page-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 3rem 2rem;
        }

        /* ── PAGE HEADER ── */
        .page-header {
            margin-bottom: 2.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.6rem;
            font-weight: 500;
            color: var(--charcoal);
            letter-spacing: 0.02em;
        }

        .page-header h1 em {
            color: var(--gold);
            font-style: italic;
        }

        .page-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 0.4rem;
            letter-spacing: 0.05em;
        }

        /* ── HERO ── */
        .hero-shell {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 2rem;
            align-items: center;
            padding: 2.5rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: linear-gradient(135deg, #F8F3EA 0%, #EFE5D3 52%, #E3D4BA 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-shell::after {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 80% 20%, rgba(201, 169, 110, 0.18), transparent 45%),
                radial-gradient(circle at 15% 80%, rgba(26, 26, 26, 0.06), transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-eyebrow {
            font-size: 0.72rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--gold-dark);
            margin-bottom: 1rem;
        }

        .hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.6rem, 5vw, 4.4rem);
            font-weight: 500;
            color: var(--charcoal);
            line-height: 1.1;
        }

        .hero-title em {
            color: var(--gold);
            font-style: italic;
        }

        .hero-subtitle {
            color: var(--text-muted);
            font-size: 1.05rem;
            max-width: 480px;
            margin: 1rem 0 1.8rem;
            font-weight: 400;
        }

        .hero-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .hero-panel {
            position: relative;
            z-index: 1;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.8rem;
            box-shadow: 0 12px 40px rgba(26, 26, 26, 0.08);
        }

        .hero-panel h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--charcoal);
            margin-bottom: 0.8rem;
        }

        .hero-metrics {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .metric-card {
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.9rem;
            background: var(--cream);
        }

        .metric-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            color: var(--gold);
        }

        .metric-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--text-muted);
        }

        .soft-divider {
            text-align: center;
            color: var(--gold);
            font-size: 1.1rem;
            margin: 3.5rem 0 2.5rem;
            letter-spacing: 0.5em;
        }

        .feature-grid-modern {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 3rem;
        }

        .feature-tile {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.6rem;
            position: relative;
            overflow: hidden;
        }

        .feature-tile::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(130deg, rgba(201, 169, 110, 0.08), transparent 45%);
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .feature-tile:hover::after {
            opacity: 1;
        }

        .feature-kicker {
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold-dark);
        }

        .feature-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.35rem;
            font-weight: 600;
            margin: 0.6rem 0 0.5rem;
            color: var(--charcoal);
        }

        .feature-desc {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        /* ── DASHBOARD ── */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.8rem;
        }

        .dashboard-actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 2rem;
        }

        .kpi-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.4rem;
        }

        .kpi-label {
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .kpi-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.2rem;
            color: var(--charcoal);
            margin: 0.5rem 0;
        }

        .kpi-sub {
            font-size: 0.82rem;
            color: var(--text-muted);
        }

        .trend-card {
            background: var(--charcoal);
            color: var(--cream);
            border-radius: 6px;
            padding: 1.5rem;
            border: 1px solid var(--charcoal-soft);
        }

        .trend-title {
            font-size: 0.78rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold-light);
        }

        .trend-bars {
            margin-top: 1.2rem;
            display: grid;
            gap: 0.6rem;
        }

        .trend-bar {
            height: 10px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 999px;
            overflow: hidden;
        }

        .trend-bar span {
            display: block;
            height: 100%;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
        }

        .activity-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.5rem;
        }

        .activity-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .activity-header h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            font-weight: 400;
            color: var(--charcoal);
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.35rem 0.7rem;
            border-radius: 999px;
            border: 1px solid var(--border);
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        /* ── ROOM DETAILS ── */
        .details-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 2rem;
            align-items: start;
        }

        .details-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.8rem;
        }

        .spec-list {
            display: grid;
            gap: 0.6rem;
            margin-top: 0.5rem;
        }

        .spec-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.55rem 0.75rem;
            border-radius: 6px;
            background: var(--cream);
            border: 1px solid var(--border);
            font-size: 0.85rem;
        }

        .spec-item span {
            color: var(--text-muted);
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .amenities-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.6rem;
            margin-top: 1rem;
        }

        .amenity-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.45rem 0.6rem;
            border-radius: 999px;
            border: 1px solid var(--border);
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-muted);
            background: var(--cream-dark);
        }

        .cta-panel {
            background: var(--charcoal);
            color: var(--cream);
            border-radius: 6px;
            padding: 1.6rem;
            border: 1px solid var(--charcoal-soft);
        }

        .cta-panel h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 400;
            color: var(--gold);
            margin-bottom: 0.5rem;
        }

        .error-panel {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 2rem;
            text-align: center;
        }

        @@media (max-width: 980px) {
            .details-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 980px) {
            .hero-shell {
                grid-template-columns: 1fr;
            }

            .dashboard-header {
                align-items: flex-start;
            }
        }

        /* ── ALERTS ── */
        .alert {
            padding: 1rem 1.4rem;
            border-radius: 3px;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
            font-weight: 400;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-success {
            background: #EBF5EE;
            border-left: 3px solid var(--success);
            color: var(--success);
        }

        .alert-error {
            background: #FAEAEA;
            border-left: 3px solid var(--error);
            color: var(--error);
        }

        /* ── CARDS ── */
        .card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            transition: box-shadow 0.25s, transform 0.25s;
        }

        .card:hover {
            box-shadow: 0 8px 32px rgba(0,0,0,0.08);
            transform: translateY(-2px);
        }

        /* ── ROOM GRID ── */
        .rooms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .room-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            transition: box-shadow 0.25s, transform 0.25s;
        }

        .room-card:hover {
            box-shadow: 0 8px 32px rgba(0,0,0,0.09);
            transform: translateY(-3px);
        }

        .room-card-banner {
            height: 8px;
            background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light));
        }

        .room-photo {
            height: 170px;
            background-size: cover;
            background-position: center;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .room-photo::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(26,26,26,0) 0%, rgba(26,26,26,0.4) 100%);
        }

        .room-card-body {
            padding: 1.6rem;
        }

        .room-number {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.2rem;
            font-weight: 600;
            color: var(--charcoal);
            line-height: 1;
        }

        .room-type-badge {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--gold-dark);
            background: var(--cream-dark);
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            margin: 0.5rem 0;
        }

        .room-price {
            font-size: 1.3rem;
            font-weight: 500;
            color: var(--charcoal);
            margin: 0.75rem 0;
        }

        .room-price span {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 300;
        }

        .availability-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #3D9E5A;
            margin-right: 0.4rem;
        }

        .availability-dot.unavailable {
            background: #C44;
        }

        /* ── BUTTONS ── */
        .btn {
            display: inline-block;
            padding: 0.75rem 1.6rem;
            border-radius: 4px;
            border: none;
            cursor: pointer;
            font-family: 'Jost', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--charcoal) 0%, #3a3a3a 100%);
            color: var(--gold-light);
            box-shadow: 0 4px 15px rgba(26, 26, 26, 0.2);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #3a3a3a 0%, var(--charcoal) 100%);
            color: var(--gold);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 26, 26, 0.3);
        }

        .btn-gold {
            background: linear-gradient(135deg, var(--gold) 0%, #D4BA87 100%);
            color: var(--charcoal);
            box-shadow: 0 4px 15px rgba(201, 169, 110, 0.3);
        }

        .btn-gold:hover {
            background: linear-gradient(135deg, #D4BA87 0%, var(--gold) 100%);
            color: var(--charcoal);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(201, 169, 110, 0.4);
        }

        .btn-outline {
            background: transparent;
            color: var(--charcoal);
            border: 1px solid var(--charcoal);
        }

        .btn-outline:hover {
            background: var(--charcoal);
            color: var(--cream);
        }

        .btn-danger {
            background: transparent;
            color: var(--error);
            border: 1px solid var(--error);
        }

        .btn-danger:hover {
            background: var(--error);
            color: var(--white);
        }

        .btn-sm {
            padding: 0.4rem 0.9rem;
            font-size: 0.72rem;
        }

        /* ── TABLE ── */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        .data-table thead tr {
            border-bottom: 2px solid var(--border);
        }

        .data-table th {
            padding: 1rem 1.2rem;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--charcoal);
            background: var(--cream-dark);
        }

        .data-table td {
            padding: 1.1rem 1.2rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            color: var(--text-main);
        }

        .data-table tbody tr:hover {
            background: var(--cream);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* ── FORM ── */
        .form-group {
            margin-bottom: 1.4rem;
        }

        .form-label {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--charcoal);
            margin-bottom: 0.6rem;
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: 2px;
            font-family: 'Jost', sans-serif;
            font-size: 0.95rem;
            color: var(--text-main);
            background: var(--white);
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.15);
        }

        .field-validation-error {
            color: var(--error);
            font-size: 0.78rem;
            margin-top: 0.3rem;
            display: block;
        }

        .validation-summary-errors {
            color: var(--error);
            font-size: 0.85rem;
            background: #FAEAEA;
            border-left: 3px solid var(--error);
            padding: 0.85rem 1rem;
            border-radius: 3px;
            margin-bottom: 1.5rem;
        }

        .form-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 2.5rem;
            max-width: 520px;
        }

        .filter-bar {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1rem;
        }

        .filter-bar .btn {
            width: 100%;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
        }

        .gallery-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            text-align: left;
        }

        .gallery-photo {
            height: 150px;
            background-size: cover;
            background-position: center;
        }

        .gallery-body {
            padding: 1.2rem 1.3rem;
        }

        /* ── AUTH LAYOUT ── */
        .auth-shell {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 2rem;
            align-items: stretch;
        }

        .auth-hero {
            background: linear-gradient(135deg, #1A1A1A 0%, #2B2B2B 45%, #1F1A14 100%);
            border: 1px solid var(--gold-dark);
            border-radius: 4px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            min-height: 320px;
            color: var(--cream);
            animation: auth-rise 520ms ease-out both;
        }

        .auth-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 20%, rgba(201, 169, 110, 0.25), transparent 45%),
                radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.08), transparent 50%);
            pointer-events: none;
        }

        .auth-hero h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.1rem;
            font-weight: 400;
            color: var(--gold);
            letter-spacing: 0.03em;
        }

        .auth-hero p {
            color: #DAD6CC;
            font-size: 0.95rem;
            margin-top: 0.75rem;
            max-width: 420px;
        }

        .auth-highlight {
            margin-top: 1.5rem;
            display: grid;
            gap: 0.75rem;
        }

        .auth-highlight-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.85rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .auth-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--gold);
            box-shadow: 0 0 0 4px rgba(201, 169, 110, 0.15);
        }

        .auth-card {
            animation: auth-rise 620ms ease-out both;
        }

        .auth-meta {
            margin-top: 1.5rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .role-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.35rem 0.65rem;
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            border-radius: 20px;
            border: 1px solid var(--border);
            background: var(--cream-dark);
            color: var(--charcoal);
        }

        .role-pill strong {
            font-weight: 600;
            letter-spacing: 0.05em;
        }

        @@keyframes auth-rise {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 980px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }
        }

        /* ── STATUS BADGE ── */
        .badge {
            display: inline-block;
            padding: 0.25rem 0.65rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .badge-available {
            background: #EBF5EE;
            color: var(--success);
        }

        .badge-occupied {
            background: #FAEAEA;
            color: var(--error);
        }

        /* ── SCROLL REVEAL ── */
        .reveal {
            opacity: 0;
            transform: translateY(18px);
            transition: opacity 0.6s ease, transform 0.6s ease;
            will-change: opacity, transform;
        }

        .reveal.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ── FOOTER ── */
        footer {
            margin-top: 5rem;
            padding: 2rem;
            text-align: center;
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.78rem;
            letter-spacing: 0.05em;
        }

        /* ── ACTIONS ROW ── */
        .actions-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .btn-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        /* ── CONFIRMATION BOX ── */
        .confirmation-box {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            max-width: 560px;
            margin: 0 auto;
            overflow: hidden;
        }

        .confirmation-box-header {
            background: var(--charcoal);
            padding: 2rem;
            text-align: center;
        }

        .confirmation-box-header h2 {
            font-family: 'Cormorant Garamond', serif;
            color: var(--gold);
            font-size: 1.8rem;
            font-weight: 400;
        }

        .confirmation-box-body {
            padding: 2rem;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--cream-dark);
            font-size: 0.9rem;
        }

        .detail-row:last-child { border-bottom: none; }

        .detail-label {
            color: var(--text-muted);
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .detail-value {
            font-weight: 500;
        }

        /* ── STAT CARDS ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1.25rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1.6rem;
            text-align: center;
        }

        .stat-number {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3rem;
            font-weight: 300;
            color: var(--gold);
            line-height: 1;
        }

        .stat-label {
            font-size: 0.72rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-top: 0.5rem;
        }

        .select-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: 2px;
            font-family: 'Jost', sans-serif;
            font-size: 0.95rem;
            color: var(--text-main);
            background: var(--white);
            cursor: pointer;
        }

        .select-control:focus {
            outline: none;
            border-color: var(--gold);
        }
    </style>
</head>
<body>

<nav>
    <a class="nav-brand" asp-controller="Home" asp-action="Index">
        Grand <span>Horizon</span>
    </a>
    <ul class="nav-links">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            if (User.IsInRole("Admin"))
            {
                <li><a asp-controller="Dashboard" asp-action="Admin">Dashboard</a></li>
            }
            else
            {
                <li><a asp-controller="Dashboard" asp-action="UserDashboard">Dashboard</a></li>
            }
        }
        <li><a asp-controller="Rooms" asp-action="Index">Browse Rooms</a></li>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <li><a asp-controller="Bookings" asp-action="MyBookings">My Bookings</a></li>
        }
        <div class="nav-divider"></div>
        @if (User.IsInRole("Admin"))
        {
            <li><a asp-controller="Rooms" asp-action="AdminIndex" style="color: var(--gold)">Admin Panel</a></li>
        }
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <li><a asp-controller="Account" asp-action="Profile">Profile</a></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link-button">Logout</button>
                </form>
            </li>
        }
        else
        {
            <li><a asp-controller="Account" asp-action="Login">Login</a></li>
        }
    </ul>
</nav>

<div class="page-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            ✓ @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            ✕ @TempData["ErrorMessage"]
        </div>
    }

    @RenderBody()
</div>

<footer>
    &copy; @DateTime.Now.Year Grand Horizon Hotel Management System
</footer>

<script>
    (function () {
        var items = document.querySelectorAll('.reveal');
        if (!items.length) return;

        if (!('IntersectionObserver' in window)) {
            items.forEach(function (el) { el.classList.add('is-visible'); });
            return;
        }

        var observer = new IntersectionObserver(function (entries, obs) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    obs.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });

        items.forEach(function (el, idx) {
            if (!el.style.transitionDelay) {
                el.style.transitionDelay = (idx * 40) + 'ms';
            }
            observer.observe(el);
        });
    })();
</script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
